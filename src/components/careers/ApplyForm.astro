---
// src/components/careers/ApplyForm.astro
interface Props {
  jobTitle: string;
}

const { jobTitle } = Astro.props;
---

<div class="form-card">
  <div class="form-card-header">
    <h2>Apply Now</h2>
    <p>Submit your application for {jobTitle}</p>
  </div>
  <div class="form-body">
    <form 
      id="applyForm" 
      action="https://formsubmit.co/recruitment.doyengroup@gmail.com" 
      method="POST" 
      enctype="multipart/form-data"
      target="formSubmitFrame"
    >
      <!-- FormSubmit.co Hidden Fields -->
      <input type="hidden" name="_subject" value={`New Job Application - ${jobTitle}`} />
      <input type="hidden" name="_replyto" id="replyto" value="" />
      <input type="hidden" name="_captcha" value="false" />
      <!-- Redirect fallback in case of no javascript -->
      <input type="hidden" name="_next" value="https://doyengroupofcompanies.com/careers" />
      <input type="hidden" name="job_title" value={jobTitle} />

      <div class="form-group">
        <label for="name">Full Name <span>*</span></label>
        <input type="text" id="name" name="name" class="form-control" placeholder="Enter your full name" required />
      </div>
      
      <div class="form-group">
        <label for="email">Email Address <span>*</span></label>
        <input type="email" id="email" name="email" class="form-control" placeholder="Enter your email address" required />
      </div>

      <div class="form-group">
        <label for="phone">Phone Number <span>*</span></label>
        <input 
          type="tel" 
          id="phone" 
          name="phone" 
          class="form-control" 
          placeholder="09171234567" 
          pattern="^(09|\+639)\d{9}$"
          title="Please enter a valid Philippine mobile number (e.g., 09171234567 or +639171234567)"
          required 
        />
        <p class="file-limit-hint">Format: 09171234567 or +639171234567</p>
      </div>

      <div class="form-group">
        <label for="message">Message / Cover Letter</label>
        <textarea id="message" name="message" class="form-control" placeholder="Tell us why you're a great fit for this role..."></textarea>
      </div>

      <div class="form-group">
        <label for="resume">Upload Resume <span>*</span></label>
        <div class="file-drop" id="fileDrop">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="upload-icon"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
          <p id="fileDropText">Drag &amp; drop your resume here or click to browse</p>
          <span class="file-name" id="fileName"></span>
          <input type="file" id="resume" name="attachment" accept=".pdf,.doc,.docx" required />
        </div>
        <p class="file-limit-hint">Accepted formats: PDF, DOC, DOCX. Max file size: 10MB.</p>
      </div>

      <button type="submit" class="submit-btn" id="submitBtn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" x2="11" y1="2" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        Submit Application
      </button>
    </form>
    
    <!-- Hidden iframe for AJAX-like background form submission -->
    <iframe name="formSubmitFrame" id="formSubmitFrame" style="display: none;"></iframe>
  </div>
</div>

<!-- Sending Overlay -->
<div class="sending-overlay" id="sendingOverlay">
  <div class="sending-spinner"></div>
  <p>Sending application…</p>
</div>

<style>
  .form-card {
    background: #fff;
    border: 1px solid #e8eaed;
    overflow: hidden;
    position: sticky;
    top: 9rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }
  .form-card-header {
    background: var(--primary);
    padding: 2rem 2.5rem;
  }
  .form-card-header h2 {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 800;
    text-transform: uppercase;
    color: white;
    letter-spacing: 0.05em;
    margin-bottom: 0;
  }
  .form-card-header p {
    font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.75);
    margin-top: 0.3rem;
  }
  .form-body {
    padding: 2.5rem;
    background: #fff;
  }
  .form-group {
    margin-bottom: 1.8rem;
  }
  .form-group label {
    display: block;
    font-size: 1.3rem;
    font-weight: 600;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.7rem;
  }
  .form-group label span {
    color: var(--primary);
  }
  .form-control {
    width: 100%;
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    color: #333;
    font-size: 1.4rem;
    font-family: var(--font-body);
    padding: 0.9rem 1.2rem;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    border-radius: 0;
  }
  .form-control:focus {
    border-color: var(--primary);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(255, 36, 0, 0.08);
  }
  textarea.form-control {
    resize: vertical;
    min-height: 10rem;
  }
  .file-drop {
    border: 2px dashed #dee2e6;
    padding: 2rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    background: #f8f9fa;
  }
  .file-drop:hover,
  .file-drop.dragover {
    border-color: var(--primary);
    background: rgba(255, 36, 0, 0.04);
  }
  .upload-icon {
    color: #bbb;
    margin: 0 auto 0.8rem;
    display: block;
  }
  .file-drop p {
    font-size: 1.3rem;
    color: #888;
    margin-bottom: 0;
  }
  .file-drop .file-name {
    font-size: 1.3rem;
    color: var(--secondary);
    margin-top: 0.5rem;
    display: none;
    font-weight: 600;
  }
  .file-drop input[type='file'] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }
  .file-limit-hint {
    font-size: 1.1rem;
    color: #aaa;
    margin-top: 0.5rem;
    margin-bottom: 0;
  }
  .submit-btn {
    width: 100%;
    padding: 1.4rem;
    background: var(--light);
    color: var(--primary);
    border: none;
    font-family: var(--font-heading);
    font-size: 1.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    border-radius: 0;
  }
  .submit-btn:hover {
    background: var(--primary);
    color: white;
  }

  @media (max-width: 900px) {
    .form-card {
      position: static;
      margin-top: 3rem;
    }
  }
</style>

<script>
  (function () {
    const form = document.getElementById('applyForm') as HTMLFormElement | null;
    const dropZone = document.getElementById('fileDrop');
    const fileInput = document.getElementById('resume') as HTMLInputElement | null;
    const fileName = document.getElementById('fileName');
    const fileText = document.getElementById('fileDropText');
    const emailInput = document.getElementById('email') as HTMLInputElement | null;
    const replyToInput = document.getElementById('replyto') as HTMLInputElement | null;
    const overlay = document.getElementById('sendingOverlay');
    const iframe = document.getElementById('formSubmitFrame') as HTMLIFrameElement | null;

    if (!form || !fileInput || !dropZone || !fileName || !fileText || !overlay || !iframe) return;

    let isSubmitting = false;

    // Keep replyto field in sync with email input so replies go back to candidate
    if (emailInput && replyToInput) {
      emailInput.addEventListener('input', () => {
        replyToInput.value = emailInput.value;
      });
    }

    function handleFile(file: File) {
      // Validate file size: limit is 10MB (10 * 1024 * 1024 bytes)
      const maxBytes = 10 * 1024 * 1024;
      if (file.size > maxBytes) {
        alert(
          `File size is too large (${(file.size / (1024 * 1024)).toFixed(1)}MB).\n` +
          'The maximum allowed file size is 10MB.'
        );
        fileInput!.value = ''; // clear input
        fileName!.style.display = 'none';
        fileText!.style.display = 'block';
        return;
      }

      fileName!.textContent = file.name;
      fileName!.style.display = 'block';
      fileText!.style.display = 'none';
    }

    fileInput.addEventListener('change', function () {
      if (fileInput.files && fileInput.files.length > 0) {
        handleFile(fileInput.files[0]);
      }
    });

    dropZone.addEventListener('dragover', function (e) {
      e.preventDefault();
      dropZone.classList.add('dragover');
    });

    dropZone.addEventListener('dragleave', function () {
      dropZone.classList.remove('dragover');
    });

    dropZone.addEventListener('drop', function (e) {
      e.preventDefault();
      dropZone.classList.remove('dragover');
      if (e.dataTransfer && e.dataTransfer.files.length > 0) {
        const file = e.dataTransfer.files[0];
        fileInput.files = e.dataTransfer.files;
        handleFile(file);
      }
    });

    // Detect when form submission to the iframe finishes loading
    iframe.addEventListener('load', function () {
      if (isSubmitting) {
        isSubmitting = false;
        overlay.classList.remove('active');
        alert('Your application has been successfully submitted! Thank you.');
        form.reset();
        fileName!.style.display = 'none';
        fileText!.style.display = 'block';
      }
    });

    form.addEventListener('submit', function (e) {
      // Final validations
      if (!fileInput.files || fileInput.files.length === 0) {
        e.preventDefault();
        alert('Please upload your resume to submit the application.');
        return;
      }

      const file = fileInput.files[0];
      if (file.size > 10 * 1024 * 1024) {
        e.preventDefault();
        alert('Please reduce your resume file size below 10MB.');
        return;
      }

      // Validate phone number format (Philippine mobile: 09XXXXXXXXX or +639XXXXXXXXX)
      const phoneInput = document.getElementById('phone') as HTMLInputElement | null;
      if (phoneInput) {
        const phoneRegex = /^(09|\+639)\d{9}$/;
        const phoneValue = phoneInput.value.trim();
        if (!phoneRegex.test(phoneValue)) {
          e.preventDefault();
          alert(
            'Please enter a valid Philippine mobile number.\n' +
            'Accepted formats: 09171234567 or +639171234567'
          );
          phoneInput.focus();
          return;
        }
      }

      isSubmitting = true;
      overlay.classList.add('active');
      
      // Let the browser submit the form natively to the target iframe
    });
  })();
</script>
