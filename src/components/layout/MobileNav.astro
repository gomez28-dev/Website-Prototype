---
// src/components/layout/MobileNav.astro
// Mobile slide-out navigation panel.
// Script replaces main.js mobile nav logic — no setTimeout, no global window hacks.

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!-- Overlay backdrop -->
<div class="mobile-nav-overlay" id="mobileNavOverlay"></div>

<!-- Slide-out nav -->
<nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
  <ul class="mobile-nav-menu">
    <li>
      <a href="/" id="mnav-home" class:list={[{ active: pathname === '/' }]}>Home</a>
    </li>
    <li>
      <a
        href="/about"
        class:list={['dropdown-toggle', { active: isActive('/about') }]}
        id="mnav-about"
      >
        About Us
        <!-- Chevron down SVG — toggled by script -->
        <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </a>
      <div class="mobile-dropdown">
        <a href="/about#who-we-are">Who We Are</a>
        <a href="/about#our-journey">Our Journey</a>
        <a href="/about#our-story">Our Story</a>
        <a href="/about#mission-vision">Mission &amp; Vision</a>
        <a href="/about#why-partner">Why Partner With Us</a>
        <a href="/about#our-facilities">Our Facilities</a>
      </div>
    </li>
    <li>
      <a href="/products" id="mnav-products" class:list={[{ active: isActive('/products') }]}>
        Products
      </a>
    </li>
    <li>
      <a href="/news" id="mnav-news" class:list={[{ active: isActive('/news') }]}>Events</a>
    </li>
    <li>
      <a href="/careers" id="mnav-career" class:list={[{ active: isActive('/careers') }]}>
        Careers
      </a>
    </li>
    <li>
      <a href="/contact" id="mnav-contact" class:list={[{ active: isActive('/contact') }]}>
        Contact Us
      </a>
    </li>
  </ul>
</nav>

<style>
  .mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 998;
  }

  .mobile-nav-overlay.active {
    display: block;
  }

  .mobile-nav {
    display: none;
    position: fixed;
    top: 7rem;
    left: 0;
    right: 0;
    bottom: 0;
    background: #fff;
    z-index: 999;
    overflow-y: auto;
    padding: 1.5rem;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    width: 100%;
    max-width: 100vw;
    box-sizing: border-box;
  }

  .mobile-nav.active {
    transform: translateX(0);
  }

  .mobile-nav-menu {
    list-style: none;
    width: 100%;
  }

  .mobile-nav-menu li {
    width: 100%;
    margin-bottom: 0.5rem;
  }

  .mobile-nav-menu a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(1rem, 3vw, 1.5rem);
    font-size: clamp(1.4rem, 4vw, 1.8rem);
    color: #333;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: 100%;
    box-sizing: border-box;
    white-space: normal;
    word-break: break-word;
    transition: color 0.2s;
  }

  .mobile-nav-menu a:hover,
  .mobile-nav-menu a.active {
    color: var(--primary);
  }

  .mobile-dropdown {
    display: none;
    padding-left: 2rem;
    background: rgba(0,0,0,0.04);
  }

  .mobile-dropdown.active {
    display: block;
  }

  .mobile-dropdown a {
    font-size: clamp(1.2rem, 3.5vw, 1.5rem) !important;
    padding: clamp(0.9rem, 2.5vw, 1.2rem) 1.5rem !important;
    text-transform: capitalize !important;
    font-weight: 400;
    justify-content: flex-start;
  }

  .chevron-icon {
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .chevron-icon.rotated {
    transform: rotate(180deg);
  }

  /* Only show on mobile */
  @media (min-width: 769px) {
    .mobile-nav,
    .mobile-nav-overlay {
      display: none !important;
    }
  }

  @media (max-width: 768px) {
    .mobile-nav {
      display: block;
    }
  }
</style>

<script>
  // ── Mobile Nav Toggle ── (replaces main.js mobile nav logic, no setTimeout)
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileNav = document.getElementById('mobileNav');
  const mobileOverlay = document.getElementById('mobileNavOverlay');

  // SVG paths for hamburger and X icons
  const BARS_PATH = `<line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/>`;
  const X_PATH = `<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>`;
  const SVG_ATTRS = `xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"`;

  let scrollY = 0;

  function openMobileNav() {
    if (!mobileNav || !mobileMenuBtn) return;
    scrollY = window.scrollY;
    document.body.style.top = '-' + scrollY + 'px';
    mobileNav.classList.add('active');
    mobileOverlay?.classList.add('active');
    document.body.classList.add('nav-open');
    mobileMenuBtn.innerHTML = `<svg ${SVG_ATTRS}>${X_PATH}</svg>`;
  }

  function closeMobileNav() {
    if (!mobileNav || !mobileMenuBtn) return;
    mobileNav.classList.remove('active');
    mobileOverlay?.classList.remove('active');
    document.body.classList.remove('nav-open');
    document.body.style.top = '';
    window.scrollTo(0, scrollY);
    mobileMenuBtn.innerHTML = `<svg ${SVG_ATTRS}>${BARS_PATH}</svg>`;
  }

  mobileMenuBtn?.addEventListener('click', () => {
    mobileNav?.classList.contains('active') ? closeMobileNav() : openMobileNav();
  });

  mobileOverlay?.addEventListener('click', closeMobileNav);

  // ── Dropdown toggles ──
  document.querySelectorAll('.dropdown-toggle').forEach((toggle) => {
    toggle.addEventListener('click', (e) => {
      e.preventDefault();
      const dd = toggle.parentElement?.querySelector('.mobile-dropdown');
      const chevron = toggle.querySelector('.chevron-icon');
      if (dd) dd.classList.toggle('active');
      if (chevron) chevron.classList.toggle('rotated');
    });
  });

  // ── Close nav on link click (non-toggle links) ──
  document.querySelectorAll('.mobile-nav-menu a:not(.dropdown-toggle)').forEach((link) => {
    link.addEventListener('click', closeMobileNav);
  });
</script>
