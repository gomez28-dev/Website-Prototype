---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formattedDate = new Date(entry.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${entry.data.title} | DOYEN News`}
  description={entry.data.excerpt}
>
  <article class="news-detail-page">
    <!-- ARTICLE HERO -->
    <header class="article-hero" style={`background-image: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.75)), url(${entry.data.image});`}>
      <div class="container article-hero-container">
        <a href="/news" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><line x1="19" x2="5" y1="12" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back to News
        </a>
        <div class="article-meta-top">
          <span class="article-tag">{entry.data.tag}</span>
          <span class="article-readtime">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {entry.data.readTime}
          </span>
        </div>
        <h1 class="article-title">{entry.data.title}</h1>
        <div class="article-author-date">
          <span class="author">By {entry.data.author}</span>
          <span class="divider">&bull;</span>
          <span class="pub-date">{formattedDate}</span>
        </div>
      </div>
    </header>

    <!-- ARTICLE BODY -->
    <section class="article-body-section">
      <div class="container body-container">
        <div class="markdown-body">
          <Content />
        </div>

        <div class="article-footer-share">
          <div class="share-title">Need to consult our team?</div>
          <div class="share-prompt">
            If you would like to ask questions regarding this update or connect with our representatives, please get in touch.
          </div>
          <div class="share-actions">
            <a href="/contact" class="btn btn-red">Contact Us Now</a>
            <a href="/news" class="btn btn-outline">Read More News</a>
          </div>
        </div>
      </div>
    </section>
  </article>

  <!-- Lightbox Modal -->
  <div id="lightbox-modal" class="lightbox-modal">
    <button id="lightbox-close" class="lightbox-btn lightbox-close" aria-label="Close lightbox">
      &times;
    </button>
    <button id="lightbox-prev" class="lightbox-btn lightbox-prev" aria-label="Previous image">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <div class="lightbox-content">
      <img id="lightbox-img" src="" alt="Gallery Image" />
    </div>
    <button id="lightbox-next" class="lightbox-btn lightbox-next" aria-label="Next image">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div id="lightbox-counter" class="lightbox-counter"></div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const galleryItems = document.querySelectorAll('.gallery-item');
    const lightbox = document.getElementById('lightbox-modal');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const counter = document.getElementById('lightbox-counter');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');

    if (!lightbox || !lightboxImg) return;

    let currentIndex = 0;
    const images: string[] = [];

    // Collect all image sources
    galleryItems.forEach((item) => {
      const img = item.querySelector('img');
      if (img) {
        images.push(img.src);
      }
    });

    if (images.length === 0) return;

    function showImage(index: number) {
      if (index < 0) {
        currentIndex = images.length - 1;
      } else if (index >= images.length) {
        currentIndex = 0;
      } else {
        currentIndex = index;
      }

      if (lightboxImg && images[currentIndex]) {
        lightboxImg.src = images[currentIndex];
        if (counter) {
          counter.textContent = `${currentIndex + 1} / ${images.length}`;
        }
      }
    }

    function openLightbox(index: number) {
      showImage(index);
      lightbox?.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox?.classList.remove('active');
      document.body.style.overflow = '';
    }

    // Attach click events to items
    galleryItems.forEach((item) => {
      item.addEventListener('click', () => {
        const idxAttr = item.getAttribute('data-index');
        const index = idxAttr ? parseInt(idxAttr, 10) : 0;
        openLightbox(index);
      });
    });

    // Close on button click
    closeBtn?.addEventListener('click', closeLightbox);

    // Close when clicking outside the image
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || e.target === document.querySelector('.lightbox-content')) {
        closeLightbox();
      }
    });

    // Next/Prev buttons
    prevBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      showImage(currentIndex - 1);
    });

    nextBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      showImage(currentIndex + 1);
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('active')) return;

      if (e.key === 'Escape') {
        closeLightbox();
      } else if (e.key === 'ArrowLeft') {
        showImage(currentIndex - 1);
      } else if (e.key === 'ArrowRight') {
        showImage(currentIndex + 1);
      }
    });
  });
</script>

<style is:global>
  /* ============================================================
     DOYEN Group of Companies — Dynamic News Article Page
     ============================================================ */

  .news-detail-page {
    background: #fff;
    min-height: 80vh;
  }

  /* ARTICLE HERO */
  .article-hero {
    position: relative;
    background-size: cover;
    background-position: center;
    padding: 14rem 0 8rem;
    color: white;
    text-align: left;
  }
  .article-hero-container {
    max-width: 90rem;
    margin: 0 auto;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    color: rgba(255,255,255,0.8);
    font-size: 1.4rem;
    font-weight: 700;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--sp-md);
    transition: color 0.2s;
  }
  .back-link:hover {
    color: #fff;
  }
  .article-meta-top {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: var(--sp-xs);
  }
  .article-tag {
    background: var(--primary);
    color: white;
    padding: 0.4rem 1.2rem;
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .article-readtime {
    display: inline-flex;
    align-items: center;
    font-size: 1.3rem;
    color: rgba(255,255,255,0.7);
  }
  .article-title {
    font-family: var(--font-heading);
    font-size: clamp(3.2rem, 5vw, 5.2rem);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.15;
    margin-bottom: var(--sp-md);
    letter-spacing: 0.02em;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
  }
  .article-author-date {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.4rem;
    color: rgba(255,255,255,0.85);
  }
  .article-author-date .divider {
    color: rgba(255,255,255,0.4);
  }

  /* ARTICLE BODY SECTION */
  .article-body-section {
    padding: 6rem 0;
  }
  .body-container {
    max-width: 80rem;
    margin: 0 auto;
  }

  /* MARKDOWN STYLING */
  .markdown-body {
    font-family: var(--font-body);
    font-size: 1.65rem;
    line-height: 1.8;
    color: #333;
  }
  .markdown-body p {
    margin-bottom: 2.4rem;
  }
  .markdown-body h2 {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    color: var(--primary);
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-top: 4rem;
    margin-bottom: 1.8rem;
    border-bottom: 2px solid #f0f0f0;
    padding-bottom: 0.8rem;
  }
  .markdown-body blockquote {
    border-left: 4px solid var(--primary);
    padding: 1rem 2rem;
    margin: 3rem 0;
    background: var(--light);
    font-style: italic;
  }
  .markdown-body blockquote p {
    margin-bottom: 0;
    font-size: 1.7rem;
    color: #444;
  }
  .markdown-body ul, .markdown-body ol {
    margin-bottom: 2.4rem;
    padding-left: 2.5rem;
  }
  .markdown-body li {
    margin-bottom: 0.8rem;
  }
  .markdown-body strong {
    color: var(--dark);
    font-weight: 700;
  }

  /* ARTICLE FOOTER ACTIONS */
  .article-footer-share {
    margin-top: 6rem;
    padding: var(--sp-md);
    background: var(--light);
    border-top: 3px solid var(--primary);
    text-align: center;
  }
  .share-title {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--primary);
    margin-bottom: 0.6rem;
  }
  .share-prompt {
    font-size: 1.45rem;
    color: #555;
    margin-bottom: var(--sp-md);
    max-width: 60rem;
    margin-left: auto;
    margin-right: auto;
  }
  .share-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .share-actions .btn {
    text-decoration: none;
    font-size: 1.4rem;
    border-radius: 50px;
  }

  /* GALLERY GRID & LIGHTBOX */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
    margin-bottom: 4rem;
  }

  .gallery-item {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    transition: transform 0.35s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.35s ease;
    cursor: pointer;
    background: #eaeaea;
  }

  .gallery-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .gallery-item:hover img {
    transform: scale(1.06);
  }

  /* LIGHTBOX MODAL */
  .lightbox-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(10, 10, 10, 0.95);
    z-index: 1000;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .lightbox-modal.active {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-content {
    max-width: 90%;
    max-height: 80%;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 5px 30px rgba(0, 0, 0, 0.5);
    transform: scale(0.95);
    transition: transform 0.3s ease;
  }

  .lightbox-modal.active .lightbox-content img {
    transform: scale(1);
  }

  .lightbox-btn {
    position: absolute;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    color: white;
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    user-select: none;
    z-index: 1010;
  }

  .lightbox-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.05);
  }

  .lightbox-btn:active {
    transform: scale(0.95);
  }

  .lightbox-close {
    top: 2rem;
    right: 2rem;
    font-size: 2.5rem;
  }

  .lightbox-prev {
    left: 2rem;
  }

  .lightbox-next {
    right: 2rem;
  }

  .lightbox-counter {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.4rem;
    font-family: var(--font-body);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .article-hero {
      padding: 10rem 0 5rem;
    }
    .article-title {
      font-size: 3rem;
    }
    .article-body-section {
      padding: 4rem 0;
    }
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    .lightbox-btn {
      width: 4rem;
      height: 4rem;
    }
    .lightbox-prev {
      left: 1rem;
    }
    .lightbox-next {
      right: 1rem;
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

