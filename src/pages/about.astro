---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Us – DOYEN Group of Companies"
  description="Learn about the DOYEN Group of Companies, our journey from foundation in 2011 to becoming a trusted Philippine supplier of fuel, tires, batteries, and Sinotruk vehicles."
>
  <!-- BANNER -->
  <div class="n-banner">
    <img src="/assets/images/truck4.webp" alt="DOYEN About Us" class="n-banner-img" />
    <div class="banner-title">
      <h1>ABOUT US</h1>
    </div>
  </div>

  <!-- WHO WE ARE -->
  <section id="who-we-are" class="wwa-section-container">
    <div class="wwa-section" id="wwaSection">
      <div class="wwa-inner">
        <div class="wwa-content">
          <div class="wwa-text-inner">
            <span class="wwa-eyebrow">Who We Are</span>
            <h2 class="wwa-heading">Driven by Excellence</h2>
            <div class="wwa-divider"></div>
            <p class="wwa-body">
              Doyen Group of Companies emerged from humble beginnings, founded by young entrepreneur
              Mr. Dean Lee. In his early career in the mining sector, he immersed himself in the complexities
              of shipments and vessel operations — and it was here, amidst heavy machinery and the constant
              flow of goods, that he saw the backbone of the Philippine economy.
            </p>
          </div>
        </div>
        <div class="wwa-image-col" id="wwaImageCol">
          <div class="wwa-image-frame" id="wwaImageFrame">
            <img src="/assets/images/ownerrrrr.webp" alt="Doyen Group Owner" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OUR JOURNEY -->
  <section id="our-journey" class="journey-section">
    <div class="journey-bg-wrapper">
      <div class="journey-section-label">
        <h2>AMAZING DEVELOPMENT ROAD, WE'VE GONE THROUGH</h2>
      </div>
      <div class="journey-header">
        <p class="journey-super" id="journeySuper"></p>
        <h2 class="journey-year-display" id="journeyYear"></h2>
        <h3 class="journey-title-display" id="journeyTitle"></h3>
        <p class="journey-desc-display" id="journeyDesc"></p>
      </div>
      <div class="journey-timeline-bar">
        <button class="journey-arrow prev" id="journeyPrev" aria-label="Previous milestone">&#8592;</button>
        <div class="journey-tl-track" id="journeyTlTrack"></div>
        <button class="journey-arrow next" id="journeyNext" aria-label="Next milestone">&#8594;</button>
      </div>
    </section>

  <!-- OUR STORY -->
  <section id="our-story" class="section">
    <div class="container">
      <h2 class="section-title">Our Story</h2>
      <div class="story-layout">
        <div class="story-content-wrapper">
          <h2 class="about-title">Driven by Purpose</h2>
          <p class="about-desc">
            We believe that every vehicle deserves quality care, and that starts with using the right products.
            Over the years, we have built strong relationships with both local and international suppliers,
            ensuring that our customers have access to genuine, high-quality products. Our team of experts
            is always ready to help you find the right products for your specific needs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION & VISION -->
  <section id="mission-vision" class="section mission-vision-section">
    <div class="container">
      <div class="mv-clean-grid">
        <div class="mv-clean-panel">
          <p class="mv-clean-tag">Our Mission</p>
          <ul class="mv-clean-list">
            <li>
              <span class="mv-clean-dot"></span>
              <span>Drive our clients' success by providing high-quality industrial solutions and essential resources that power their operations.</span>
            </li>
            <li>
              <span class="mv-clean-dot"></span>
              <span>Operating as a comprehensive, one-stop destination for companies seeking high-quality assets with the best value for our client's investment.</span>
            </li>
            <li>
              <span class="mv-clean-dot"></span>
              <span>Ensuring the highest standards of quality and affordability across our entire portfolio.</span>
            </li>
            <li>
              <span class="mv-clean-dot"></span>
              <span>Simplifying the procurement process and supporting exceptional after-sales service to build lasting partnerships with our clients.</span>
            </li>
            <li>
              <span class="mv-clean-dot"></span>
              <span>Strive to build long-term partnerships with our clients and stakeholders, create opportunities for our employees, uphold integrity in every transaction, and contribute to the continuous growth of the industries and communities we serve.</span>
            </li>
          </ul>
        </div>
        <div class="mv-clean-panel">
          <p class="mv-clean-tag">Our Vision</p>
          <p class="mv-clean-body">
            To be a leading and trusted company in the industry known for excellence, reliability, top-tier
            service, and cost-efficient products, dedicated to fueling the growth and success of the industries
            and communities that we serve.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY PARTNER -->
  <section id="why-partner" class="partner-section">
    <div class="container partner-section-inner">
      <h2 class="section-title">Why Partner With Us?</h2>
      <div class="partner-intro">
        <h2 class="about-title">A Partnership Built on<br />Shared Growth</h2>
        <p class="about-desc">
          At DOYEN, we believe that when our partners succeed, we succeed. That is why we go beyond simple
          transactions — we invest in the long-term growth of every dealer, fleet operator, and business we
          work with. From onboarding support to ongoing technical advice, we are with you at every step.
        </p>
        <p class="about-desc">
          Our network spans the entire Philippines, and our team has the expertise to help you navigate
          product choices, pricing, and market opportunities. Partnering with DOYEN means access to a
          trusted name, world-class brands, and a dedicated support team.
        </p>
      </div>
      <div class="partner-reasons">
        <div class="reason-card">
          <div class="reason-title">Excellent Customer Service</div>
          <p class="reason-desc">
            We prioritize your business needs with a professional and proactive approach, ensuring that every
            interaction adds value to your operation.
          </p>
        </div>
        <div class="reason-card">
          <div class="reason-title">Competitive and Reliable Supplies</div>
          <p class="reason-desc">
            We leverage our group's collective strength to offer premium-tier products and services at highly
            competitive prices, ensuring you get the best return on your investment.
          </p>
        </div>
        <div class="reason-card">
          <div class="reason-title">Unwavering Corporate Responsibility</div>
          <p class="reason-desc">
            We take full ownership of our commitments with the highest level of accountability and Professional
            integrity.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- OUR FACILITIES -->
  <section id="our-facilities" class="section">
    <div class="container">
      <h2 class="section-title">Our Facilities</h2>
      <div class="facilities-grid">
        <div class="facility-card">
          <div class="facility-img">
            <img src="/assets/images/DEPOT.webp" alt="DOYEN Warehouse Depot" />
            <div class="facility-img-overlay">
              <h4>Warehouse &amp; Distribution</h4>
            </div>
          </div>
          <div class="facility-body">
            <p>
              Our facilities in San Simon, Pampanga and Valenzuela City provide strategic accessibility to
              customers in Luzon and other islands. Expansion to other locations is underway.
            </p>
          </div>
        </div>
        <div class="facility-card">
          <div class="facility-img">
            <img src="/assets/images/GARAGE 1.webp" alt="Storage Facility" />
            <div class="facility-img-overlay">
              <h4>Storage &amp; Inventory</h4>
            </div>
          </div>
          <div class="facility-body">
            <p>State-of-the-art storage systems with real-time inventory tracking for maximum efficiency.</p>
          </div>
        </div>
        <div class="facility-card">
          <div class="facility-img">
            <img src="/assets/images/GARAGE 3.webp" alt="Delivery Fleet" />
            <div class="facility-img-overlay">
              <h4>Delivery Fleet</h4>
            </div>
          </div>
          <div class="facility-body">
            <p>Modern delivery fleet equipped to handle nationwide distribution efficiently and safely.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-mock">
    <h2>Need Help Finding the Right Product?</h2>
    <p>Contact our team for expert advice and personalized product recommendations for your specific needs</p>
    <div class="cta-btns">
      <a href="/contact" class="cta-btn primary">Contact Us</a>
      <a href="/products" class="cta-btn secondary">View Products</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Global page layout defaults for About page */
  .section {
    padding: var(--sp-xl) 0;
  }

  /* WHO WE ARE */
  .wwa-section-container {
    background: #fff;
    position: relative;
    padding: 3.5rem 0;
    overflow: hidden;
  }
  .wwa-section {
    width: 100%;
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 var(--sp-md);
  }
  .wwa-inner {
    display: flex;
    align-items: center;
    gap: 0;
    position: relative;
    width: 100%;
    z-index: 1;
  }
  .wwa-content {
    flex: 0 0 60%;
    max-width: 60%;
    z-index: 2;
    padding: 0 5rem 0 8rem;
    box-sizing: border-box;
  }
  .wwa-eyebrow {
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 1.6rem;
    display: block;
  }
  .wwa-heading {
    font-family: var(--font-heading);
    font-size: 5.2rem;
    font-weight: 800;
    color: #000;
    line-height: 1.1;
    margin: 0 0 2.6rem 0;
    text-transform: uppercase;
  }
  .wwa-divider {
    width: 4.8rem;
    height: 3px;
    background: var(--primary);
    margin: 0 0 2.6rem 0;
  }
  .wwa-body {
    font-size: 1.75rem;
    color: #000;
    line-height: 1.95;
    margin-bottom: 2.2rem;
  }
  .wwa-image-col {
    flex: 0 0 40%;
    max-width: 40%;
    align-self: stretch;
    display: flex;
    align-items: center;
    position: relative;
  }
  .wwa-image-frame {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 50rem;
    overflow: hidden;
  }
  .wwa-image-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .wwa-content .wwa-text-inner {
    display: block;
    text-align: left;
  }

  /* OUR STORY */
  .story-content-wrapper {
    text-align: center;
    max-width: 80rem;
    margin: 0 auto;
  }
  .about-title {
    font-family: var(--font-heading);
    font-size: 5.2rem;
    font-weight: 800;
    color: #000;
    line-height: 1.1;
    margin: 0 0 2.6rem;
    text-transform: uppercase;
  }
  .about-desc {
    font-size: 1.7rem;
    line-height: 1.8;
    margin-bottom: var(--sp-md);
    color: #333;
  }

  /* JOURNEY SECTION */
  .journey-section {
    position: relative;
    height: auto;
    min-height: unset;
    max-height: unset;
    overflow: hidden;
    display: block;
  }
  .journey-bg-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .journey-bg-a, .journey-bg-b {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: opacity 0.8s;
  }
  .journey-bg-b {
    opacity: 0;
  }
  .journey-dark-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.52);
    z-index: 1;
    pointer-events: none;
  }
  .journey-section-label {
    position: absolute;
    top: 3.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    text-align: center;
    pointer-events: none;
    width: 90%;
  }
  .journey-section-label h2 {
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #fff;
  }
  .journey-header {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 10rem 4rem 0;
    margin-bottom: 3rem;
  }
  .journey-super {
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.95);
  }
  .journey-year-display {
    font-size: clamp(6rem, 13vw, 11rem);
    font-weight: 900;
    color: #fff;
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
    font-family: var(--font-heading);
  }
  .journey-title-display {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    margin-top: 1rem;
  }
  .journey-desc-display {
    font-size: clamp(1.4rem, 1.8vw, 1.8rem);
    color: rgba(255, 255, 255, 0.98);
    max-width: 65rem;
    line-height: 1.75;
    margin: 1.5rem auto 0;
  }
  .journey-timeline-bar {
    position: relative;
    z-index: 10;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4rem 6rem;
  }
  .journey-arrow {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.6);
    width: 3.8rem;
    height: 3.8rem;
    border-radius: 50%;
    font-size: 1.6rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: color 0.2s, border-color 0.2s;
  }
  .journey-arrow:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.8);
  }
  .journey-tl-track {
    flex: 0.5;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .journey-tl-track::before {
    content: '';
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 0.5px;
    background: rgba(255, 255, 255, 0.35);
  }
  :global(.journey-tl-year) {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    cursor: pointer;
    transition: transform 0.3s;
  }
  :global(.journey-tl-year:hover) {
    transform: translateY(-3px);
  }
  :global(.journey-tl-dot) {
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.75);
    border: 2px solid rgba(255, 255, 255, 0.85);
    margin-bottom: 0.8rem;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }
  :global(.journey-tl-year.is-active .journey-tl-dot),
  :global(.journey-tl-year:hover .journey-tl-dot) {
    background: var(--primary);
    border-color: #dcdcdc;
    transform: scale(1.2);
  }
  :global(.journey-tl-label) {
    font-size: 1.3rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  :global(.journey-tl-year.is-active .journey-tl-label) {
    color: #fff;
    font-size: 1.5rem;
  }

  /* MISSION & VISION */
  .mission-vision-section {
    background-color: #fff;
  }
  .mv-clean-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-md);
  }
  .mv-clean-panel {
    background: #fff;
    padding: 4rem 3.5rem 3rem;
    border: 1px solid #e8e8e8;
    display: flex;
    flex-direction: column;
  }
  .mv-clean-tag {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--primary);
    margin-bottom: 0.8rem;
  }
  .mv-clean-body {
    font-size: 1.5rem;
    color: #333;
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  .mv-clean-list {
    list-style: none;
    margin: 0 0 auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .mv-clean-list li {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
    font-size: 1.45rem;
    color: #555;
    line-height: 1.6;
  }
  .mv-clean-dot {
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    margin-top: 0.6rem;
    background: var(--accent);
  }

  /* WHY PARTNER */
  .partner-section {
    padding: var(--sp-xl) 0;
    background: #fdfdfd;
  }
  .partner-intro {
    text-align: center;
    max-width: 90rem;
    margin: 0 auto var(--sp-xl);
  }
  .partner-reasons {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-md);
  }
  .reason-card {
    background: #fff;
    padding: 3rem 2.5rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    transition: transform 0.3s, box-shadow 0.3s;
    position: relative;
    overflow: hidden;
  }
  .reason-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s;
  }
  .reason-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 36px rgba(0,0,0,0.11);
  }
  .reason-card:hover::after {
    transform: scaleX(1);
  }
  .reason-title {
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 1rem;
  }
  .reason-desc {
    font-size: 1.5rem;
    color: #666;
    line-height: 1.75;
  }

  /* FACILITIES */
  .facilities-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-md);
    margin-top: var(--sp-lg);
  }
  .facility-card {
    overflow: hidden;
    box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    transition: transform 0.3s, box-shadow 0.3s;
    background: #fff;
  }
  .facility-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.15);
  }
  .facility-img {
    height: 32rem;
    overflow: hidden;
    position: relative;
  }
  .facility-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .facility-card:hover .facility-img img {
    transform: scale(1.06);
  }
  .facility-img-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem 1.8rem;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
  }
  .facility-img-overlay h4 {
    color: #fff;
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 700;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
    text-transform: uppercase;
  }
  .facility-body {
    padding: 1.5rem;
  }
  .facility-body p {
    color: #444;
    font-size: 1.5rem;
    line-height: 1.7;
  }

  /* RESPONSIVE STYLES */
  @media (max-width: 1024px) {
    .wwa-inner {
      flex-direction: column;
    }
    .wwa-content {
      flex: none !important;
      max-width: 100% !important;
      padding: 4rem !important;
      transform: translateX(0) !important;
    }
    .wwa-divider {
      margin: 0 auto 2.4rem !important;
    }
    .wwa-text-inner {
      text-align: center !important;
    }
    .wwa-image-col {
      flex: none !important;
      max-width: 100% !important;
      width: 100% !important;
    }
    .wwa-image-frame {
      min-height: 35rem;
    }
    .facilities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .partner-reasons {
      grid-template-columns: repeat(2, 1fr);
    }
    .mv-clean-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .wwa-heading {
      font-size: clamp(3rem, 7vw, 5.2rem);
    }
    .wwa-body {
      font-size: clamp(1.4rem, 3.5vw, 1.75rem);
    }
    .journey-year-display {
      font-size: clamp(5rem, 12vw, 9rem);
    }
    .journey-desc-display {
      font-size: clamp(1.3rem, 3vw, 1.8rem);
      padding: 0 1rem;
    }
    .journey-section {
      height: auto;
      min-height: unset;
      max-height: unset;
      padding-top: 8rem;
      padding-bottom: 2rem;
    }
    .journey-header {
      padding: 0 2rem;
      gap: 0.8rem;
      flex: unset;
      width: 100%;
    }
    .journey-section-label {
      position: relative;
      top: unset;
      left: unset;
      transform: none;
      margin-bottom: 1.5rem;
    }
    .journey-timeline-bar {
      padding: 1.5rem 2rem 2rem;
    }
    .about-title {
      font-size: clamp(3rem, 7vw, 5.2rem);
    }
    .about-desc {
      font-size: clamp(1.4rem, 3.5vw, 1.7rem);
    }
    .mv-clean-tag {
      font-size: clamp(2rem, 5vw, 3rem);
    }
    .facilities-grid {
      grid-template-columns: 1fr;
    }
    .partner-reasons {
      grid-template-columns: 1fr;
    }
    .facility-img {
      height: 24rem;
    }
    .reason-card {
      padding: 2.2rem 1.8rem;
    }
    :global(.journey-tl-label) {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .journey-section-label h2 {
      font-size: 1.2rem;
      letter-spacing: 0.1em;
      padding: 0 1rem;
      text-align: center;
    }
  }
</style>

<script>
  // JOURNEY TIMELINE
  (function () {
    const MILESTONES = [
      {
        year: '2011',
        super: 'WHERE IT ALL STARTED',
        title: 'Foundation',
        desc: "In 2011, the journey began securing its position as a primary importer of Sinotruk in the Philippines. By 2012, Mrs. Bernice Lee stepped in to co-lead the operations, driving the expansion that defined the company's early years. This growth solidified with its new home as the company's first office in Quezon City.",
        bg: '/assets/images/truck4.webp'
      },
      {
        year: '2013',
        super: 'EARLY GROWTH',
        title: 'Operational Expansion',
        desc: 'By 2013, the company expanded its operations with a growing team and an increasing fleet, establishing a reputation for reliability in the logistics sector across Luzon. The foundation laid during these years enabled the company to take on larger partnerships and more complex supply chains.',
        bg: '/assets/images/truck4.webp'
      },
      {
        year: '2015',
        super: 'A NEW CHAPTER',
        title: 'Brand Partnerships',
        desc: 'In 2015, with the establishment of Doyen Logistics, the company began servicing the Luzon region with a lean operation of 3 units parked in a modest street garage and a dedicated team of over 10 employees. What began as a small-scale operation quickly gained a reputation for reliability and localized expertise.',
        bg: '/assets/images/truck4.webp'
      },
      {
        year: '2016',
        super: 'SCALING UP',
        title: 'Logistics Expansion',
        desc: 'In 2016, Doyen Logistics scaled its operations with a larger fleet and expanded service areas, reinforcing its presence across the Philippines. This period marked a significant increase in both capacity and reach, laying the groundwork for nationwide coverage.',
        bg: '/assets/images/truck4.webp'
      },
      {
        year: '2018',
        super: 'DIVERSIFYING',
        title: 'Portfolio Diversification',
        desc: 'Recognizing that fuel is the primary overhead in logistics, Doyen International Trading Corporation was established, marking our transition into diversifying our portfolio. By securing the supply chain, Doyen moved from being a service provider to a self-sustaining industrial entity.',
        bg: '/assets/images/truck4.webp'
      },
      {
        year: '2020',
        super: 'BUILDING RESILIENCE',
        title: 'Product Expansion',
        desc: 'Despite global challenges, the group expanded further with the introduction of DK Ventures Inc., which specializes in importing Tires and Batteries, alongside the launch of Teko to spearhead the sales of our fuel dispensers. This created a complete ecosystem, ensuring our partners had access to every critical component of the transport lifecycle.',
        bg: '/assets/images/truck4.webp'
      },
      {
        year: '2025',
        super: 'LEADING THE INDUSTRY',
        title: 'Industry Leader',
        desc: 'To accommodate the growth and centralize the operations of the group, we reached a major milestone by establishing our headquarters in Valenzuela, solidifying our long-term commitment to industrial excellence. Today, Doyen stands as a trusted name across multiple industries.',
        bg: '/assets/images/truck4.webp'
      }
    ];

    const bgA = document.getElementById('journeyBgA');
    const bgB = document.getElementById('journeyBgB');
    const elSup = document.getElementById('journeySuper');
    const elYr = document.getElementById('journeyYear');
    const elTi = document.getElementById('journeyTitle');
    const elDe = document.getElementById('journeyDesc');
    const track = document.getElementById('journeyTlTrack');
    const prevBtn = document.getElementById('journeyPrev');
    const nextBtn = document.getElementById('journeyNext');

    if (!bgA || !bgB || !elSup || !elYr || !elTi || !elDe || !track || !prevBtn || !nextBtn) return;

    let cur = 0;
    let bgAct = 'a';
    let trans = false;

    // Create timeline dots
    MILESTONES.forEach((m, i) => {
      const el = document.createElement('div');
      el.className = 'journey-tl-year' + (i === 0 ? ' is-active' : '');
      el.innerHTML = '<div class="journey-tl-dot"></div><span class="journey-tl-label">' + m.year + '</span>';
      el.addEventListener('click', () => {
        goTo(i);
      });
      track.appendChild(el);
    });

    function setContent(i: number, dir: number) {
      if (!elSup || !elYr || !elTi || !elDe) return;
      const elements = [elSup, elYr, elTi, elDe];
      elements.forEach((el) => {
        el.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
        el.style.opacity = '0';
        el.style.transform = dir > 0 ? 'translateY(20px)' : 'translateY(-20px)';
      });

      setTimeout(() => {
        elSup.textContent = MILESTONES[i].super;
        elYr.textContent = MILESTONES[i].year;
        elTi.textContent = MILESTONES[i].title;
        elDe.textContent = MILESTONES[i].desc;
        elements.forEach((el) => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        });
      }, 320);
    }

    function setBg(i: number) {
      if (!bgA || !bgB) return;
      const url = "url('" + MILESTONES[i].bg + "')";
      if (bgAct === 'a') {
        bgB.style.backgroundImage = url;
        bgB.style.transition = 'opacity 0.85s ease';
        bgB.style.opacity = '1';
        bgA.style.opacity = '0';
        bgAct = 'b';
      } else {
        bgA.style.backgroundImage = url;
        bgA.style.transition = 'opacity 0.85s ease';
        bgA.style.opacity = '1';
        bgB.style.opacity = '0';
        bgAct = 'a';
      }
    }

    function goTo(i: number) {
      if (i === cur || trans) return;
      trans = true;
      const dir = i > cur ? 1 : -1;
      cur = i;
      setBg(i);
      setContent(i, dir);

      const trackYears = track!.querySelectorAll('.journey-tl-year');
      trackYears.forEach((el, j) => {
        el.classList.toggle('is-active', j === i);
      });

      setTimeout(() => {
        trans = false;
      }, 500);
    }

    // Set initial values
    bgA.style.backgroundImage = "url('" + MILESTONES[0].bg + "')";
    bgA.style.opacity = '1';
    bgB.style.opacity = '0';
    elSup.textContent = MILESTONES[0].super;
    elYr.textContent = MILESTONES[0].year;
    elTi.textContent = MILESTONES[0].title;
    elDe.textContent = MILESTONES[0].desc;

    prevBtn.addEventListener('click', () => {
      goTo((cur - 1 + MILESTONES.length) % MILESTONES.length);
    });
    nextBtn.addEventListener('click', () => {
      goTo((cur + 1) % MILESTONES.length);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        goTo((cur - 1 + MILESTONES.length) % MILESTONES.length);
      }
      if (e.key === 'ArrowRight') {
        goTo((cur + 1) % MILESTONES.length);
      }
    });

    // Touch gestures on timeline
    let tsx = 0;
    const journeySec = document.getElementById('our-journey');
    if (journeySec) {
      journeySec.addEventListener('touchstart', (e) => {
        tsx = e.touches[0].clientX;
      }, { passive: true });
      journeySec.addEventListener('touchend', (e) => {
        const d = tsx - e.changedTouches[0].clientX;
        if (Math.abs(d) > 50) {
          goTo(d > 0 ? (cur + 1) % MILESTONES.length : (cur - 1 + MILESTONES.length) % MILESTONES.length);
        }
      }, { passive: true });
    }
  })();
</script>
